# Required — Tavily Search API (https://tavily.com)
TAVILY_API_KEY=tvly-your-key-here

# LLM Provider — at least one required for AI Deep Read
OHMYAPI_KEY=sk-your-ohmyapi-key
# OHMYAPI_BASE_URL=https://api.openai.com/v1
# OHMYAPI_MODEL_NAME=gpt-5.4

# Vision / OCR — defaults to LLM provider if not set
# VISION_BASE_URL=http://127.0.0.1:30000/v1
# VISION_MODEL=Qwen/Qwen3.5-2B
# VISION_API_TOKEN=EMPTY

# Optional: Custom topics (semicolon-separated, format: Label|Query)
# RADAR_TOPICS=推理优化|LLM Inference RAG optimization;安全性|LLM Security jailbreak
